{
  "name": "@ohos/hvigor-arkts-compose",
  "version": "6.24.2",
  "description": "hvigor-arkts-compose",
  "main": "./dist/index.js",
  "scripts": {
    "patch-publish": "npm --no-git-tag-version version prepatch&&npm publish",
    "prepack": "npm run ugly-build",
    "build": "tsc -p .",
    "watch": "tsc --watch",
    "clean": "tsc --build --clean",
    "rebuild": "npm run clean&&npm run build",
    "uglify": "node uglify.mjs",
    "copy-native": "node copy-native.js",
    "ugly-build": "npm run clean && npm run build && npm run uglify",
    "test": "jest",
    "coverage": "nyc --clean jest --coverage",
    "fix": "eslint ./**/*.ts --fix"
  },
  "dependencies": {
    "oxc-resolver": "1.11.0-htrunk1.AllScenario.devecostudio.r5",
    "@babel/core": "7.28.4",
    "@babel/plugin-transform-class-properties": "7.27.1",
    "@baize/wdk": "0.7.2",
    "@ohos/hvigor-arkts-base": "6.24.2",
    "@ohos/hvigor-common": "6.24.2",
    "@ohos/hvigor-logger": "6.24.2",
    "@ohos/coverage": "2.0.47",
    "@rollup/plugin-babel": "6.0.3",
    "@rollup/plugin-commonjs": "24.1.0",
    "@rollup/plugin-json": "6.0.0",
    "@rollup/plugin-node-resolve": "15.0.1",
    "@rollup/plugin-terser": "0.3.0",
    "@rollup/pluginutils": "5.0.2",
    "glob": "10.5.0",
    "source-map": "0.7.5"
  },
  "overrides": {
    "glob": {
      "minimatch": "9.0.9"
    },
    "@rollup/plugin-commonjs": {
      "minimatch": "5.1.8"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.node",
    "dist/**/*.d.ts",
    "res/**/*"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*"
  },
  "author": "huawei",
  "ohos": {
    "org": "huawei"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "keywords": [
    "hvigor",
    "OpenHarmony"
  ]
}
